{
  "productName": "db_ide",
  "version": "0.1.0",
  "identifier": "com.db-ide.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "db_ide",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
