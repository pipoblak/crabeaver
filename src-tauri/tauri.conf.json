{
  "productName": "Crabeaver",
  "version": "0.0.0",
  "identifier": "com.crabeaver.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Crabeaver",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
